# Luckfox Pico Ultra W — RGB adapter MCU reset
# The 4" 720x720 panel adapter board has a CH32V003F4 MCU that drives the
# panel's internal controller. Its reset/enable line is tied to GPIO1 pin 1.
# Without this, the MCU stays held in reset and never runs the panel init
# sequence, so the panel shows nothing no matter what the VOP scans out.
# U-Boot releases the MCU reset early via luckfox_execute_cmd() in board.c.
CONFIG_LUCKFOX_EXECUTE_CMD=y
# The luckfox_execute_cmd() helper invokes `run_command("gpio set 1 1")`,
# so the gpio console command must be compiled in.
CONFIG_CMD_GPIO=y
