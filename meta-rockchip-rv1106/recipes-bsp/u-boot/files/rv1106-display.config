# Enable U-Boot display pipeline for RGB LCD (VOP → RGB → panel)
# Required so kernel DRM driver can inherit an already-running display
CONFIG_DM_I2C=y
CONFIG_DISPLAY=y
CONFIG_DM_VIDEO=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_DRM_ROCKCHIP_PANEL=y
CONFIG_DRM_ROCKCHIP_RGB=y
CONFIG_VIDEO_BPP8=y
CONFIG_VIDEO_BPP16=y
CONFIG_VIDEO_BPP32=y

# PWM backlight
CONFIG_DM_PWM=y
CONFIG_PWM_ROCKCHIP=y
CONFIG_BACKLIGHT_PWM=y

# Regulator framework (needed by display/panel drivers)
CONFIG_DM_REGULATOR=y

# DRM memory reservation for framebuffer
CONFIG_DRM_MEM_RESERVED_SIZE_MBYTES=4

# Video console — disabled for now to keep serial console active
# CONFIG_ROCKCHIP_VIDCONSOLE is not set
